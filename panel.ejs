<!DOCTYPE html>
<html>
<head>
    <title>Painel Admin - The Kria MC</title>
    <style>
        body {
            background: #0a0a0a;
            color: white;
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 40px;
        }

        h1 {
            color: red;
            margin-bottom: 30px;
        }

        table {
            width: 90%;
            margin: auto;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            border: 1px solid red;
        }

        th {
            background: #222;
        }

        .btn {
            background-color: red;
            color: white;
            padding: 8px 12px;
            text-decoration: none;
            margin: 2px;
            border-radius: 5px;
            display: inline-block;
        }

        .btn:hover {
            background-color: darkred;
        }

        .status {
            font-weight: bold;
        }

        a {
            color: white;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <h1>Painel Admin</h1>

    <table>
        <tr>
            <th>ID</th>
            <th>Nick</th>
            <th>Produto</th>
            <th>Status</th>
            <th>Comprovante</th>
            <th>Ações</th>
        </tr>

        <% orders.forEach(o => { %>
        <tr>
            <td><%= o.id %></td>
            <td><%= o.nickname %></td>
            <td><%= o.product %></td>
            <td class="status"><%= o.status %></td>
            <td>
                <% if (o.proof) { %>
                    <a href="<%= o.proof %>" target="_blank">Ver</a>
                <% } %>
            </td>
            <td>
                <a href="/update/<%= o.id %>/PENDENTE" class="btn">Pendente</a>
                <a href="/update/<%= o.id %>/CONCLUIDO" class="btn">Concluído</a>
                <a href="/update/<%= o.id %>/RECUSADO" class="btn">Recusado</a>
            </td>
        </tr>
        <% }) %>
    </table>

</body>
</html>